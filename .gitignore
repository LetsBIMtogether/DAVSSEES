
# Visual Studio cache/options directory
.vs/

# Build results
[Bb]in/
[Oo]bj/

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
# except build/, which is used as an MSBuild target.
!**/packages/build/
# Uncomment if necessary however generally it will be regenerated when needed
#!**/packages/repositories.config
# NuGet v3's project.json files produces more ignoreable files
*.nuget.props
*.nuget.targets

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Ignore Windows thumbnail cache files
**/Thumbs.db

# Visual Studio cache files
# files ending in .cache can be ignored
*.[Cc]ache
# but keep track of directories ending in .cache
!*.[Cc]ache/

# Others
ClientBin/                # Silverlight / old ASP.NET output (not Orleans)
~$*                       # Office temp files
*~                        # Editor backup files
*.dbmdl                   # SQL / database model files
*.dbproj.schemaview       # SQL Server tooling files
*.jfm                     # Legacy Java / tooling metadata
*.pfx                     # Certificates / signing keys (IMPORTANT)
*.publishsettings         # Azure publish credentials (IMPORTANT)
node_modules/             # Node.js dependencies
orleans.codegen.cs        # Orleans generated code

# Backup & report files from converting an old project file
# to a newer Visual Studio version. Backup files are not needed,
# because we have git ;-)
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm

# Misc
CTC-VS.ps1
CTC-VS.txt
